FROM python:3.13-slim

WORKDIR /app

COPY requirements-nomikai.txt .
RUN pip install --no-cache-dir -r requirements-nomikai.txt

COPY nomikai_api.py precompute.py ./
COPY statione.csv join.csv line.csv ./
COPY static/ static/

# Pre-compute station data pickle at build time (faster cold start)
RUN python precompute.py

EXPOSE 8501

HEALTHCHECK CMD curl --fail http://localhost:8501/api/config || exit 1

ENTRYPOINT ["uvicorn", "nomikai_api:app", "--host", "0.0.0.0", "--port", "8501"]
